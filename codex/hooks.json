{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.codex/hooks/block-dangerous-commands.sh",
            "timeout": 5,
            "statusMessage": "Checking dangerous shell command"
          }
        ]
      }
    ]
  }
}
